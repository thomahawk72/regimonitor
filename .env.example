# RegiMonitor Environment Variables
# Kopier denne filen til .env og fyll inn dine verdier

# Server Configuration
PORT=3000
NODE_ENV=development

# Datainnsamling (sekunder mellom hver webhook-sending)
QUALITY_INTERVAL=5

# Eksterne API URLs
IP_API_URL=http://ip-api.com/json

# ISP-liste for 5G-operatører (kommaseparert - match mot ip-api.com)
ISP=Telenor Mobil,Telia,Ice,Altibox AS,OneCall,Chilimobil,TalkMore,Phonero

# Kvalitetsterskler (millisekunder)
QUALITY_PING_EXCELLENT_MAX=50
QUALITY_PING_GOOD_MAX=100
QUALITY_PING_POOR_MAX=200
QUALITY_JITTER_EXCELLENT_MAX=10
QUALITY_JITTER_GOOD_MAX=30
QUALITY_JITTER_POOR_MAX=50

# Avanserte kvalitetsinnstillinger
QUALITY_PING_INTERVAL_SECONDS=5
QUALITY_JITTER_WINDOW_SECONDS=45
QUALITY_CONSECUTIVE_THRESHOLD_COUNT=3
QUALITY_JITTER_SAMPLES_PER_MEASUREMENT=5
QUALITY_PING_SERVER=google.com

# Webhook for nettverksmetrikk
# Eksempel:
# WEBHOOK_METRICS_URL=http://localhost:3000/api/webhooks/metrics
# WEBHOOK_METRICS_API_KEY=dev-api-key
# WEBHOOK_METRICS_MIN_INTERVAL_MS=7000
WEBHOOK_METRICS_URL=
WEBHOOK_METRICS_API_KEY=
WEBHOOK_METRICS_MIN_INTERVAL_MS=7000

# Sikkerhetsmerknad:
# ALDRI commit .env-filer med ekte API-nøkler til git!
# Bruk .env.local eller lignende for lokale hemmeligheter
