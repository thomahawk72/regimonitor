# RegiMonitor Environment Variables
# Kopier til .env og fyll inn verdier

# === PÅKREVD FOR WEBHOOK ===
WEBHOOK_METRICS_URL=https://din-webhook-url
WEBHOOK_METRICS_API_KEY=din-api-nøkkel

# === SERVER ===
PORT=3000
NODE_ENV=development

# === DATAINNSAMLING ===
# Sekunder mellom hver måling og webhook-sending
QUALITY_INTERVAL=5

# === NETTVERK (ip-api.com) ===
IP_API_URL=http://ip-api.com/json

# ISP-liste for 5G-operatører (kommaseparert)
# Match mot "isp" fra ip-api.com → connectionType "5G", ellers "LAN"
ISP=Telenor Mobil,Telia,Ice,Altibox AS,OneCall,Chilimobil,TalkMore,Phonero

# === PING-MÅLING ===
QUALITY_PING_SERVER=google.com

# === KVALITETSTERSKLER (millisekunder) ===
QUALITY_PING_EXCELLENT_MAX=50
QUALITY_PING_GOOD_MAX=100
QUALITY_PING_POOR_MAX=200
QUALITY_JITTER_EXCELLENT_MAX=10
QUALITY_JITTER_GOOD_MAX=30
QUALITY_JITTER_POOR_MAX=50

# === AVANSERTE KVALITETSINNSTILLINGER ===
QUALITY_JITTER_WINDOW_SECONDS=45
QUALITY_CONSECUTIVE_THRESHOLD_COUNT=3
QUALITY_JITTER_SAMPLES_PER_MEASUREMENT=5

# === WEBHOOK RATE-LIMIT ===
WEBHOOK_METRICS_MIN_INTERVAL_MS=7000

# === VALGFRI ===
# DEBUG=1  # Aktiver debug-logging
